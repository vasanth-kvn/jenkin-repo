pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/<vasanth>/my-app.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t my-app .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 5000:5000 my-app'
            }
        }
    }
}
